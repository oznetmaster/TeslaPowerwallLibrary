{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "TeslaPowerwallLibrary/TeslaPowerwallLibrary.csproj"
          ],
          "src": ".."
        }
      ],
      "properties": {
        "TargetFramework": "net472"
      },
      "dest": "api",
      "disableGitFeatures": false
    },
    {
      "src": [
        {
          "files": [
            "TeslaPowerwallLibrary.Login/TeslaPowerwallLibrary.Login.csproj"
          ],
          "src": ".."
        }
      ],
      "properties": {
        "TargetFramework": "net472"
      },
      "dest": "api-login",
      "disableGitFeatures": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml"
        ]
      },
      {
        "files": [
          "api/**.md"
        ]
      },
      {
        "files": [
          "api-login/**.yml"
        ]
      },
      {
        "files": [
          "api-login/**.md"
        ]
      },
      {
        "files": [
          "articles/**.md"
        ]
      },
      {
        "files": [
          "index.md"
        ]
      },
      {
        "files": [
          "toc.yml"
        ]
      }
    ],
    "globalMetadata": {
      "_appTitle": "TeslaPowerwallLibrary API"
    },
    "output": "_site",
    "template": [
      "default",
      "modern"
    ]
  }
}