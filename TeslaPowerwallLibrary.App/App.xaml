<Application x:Class="TeslaPowerwallLibrary.App.App"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:conv="clr-namespace:TeslaPowerwallLibrary.App.Converters"
			 xmlns:vm="clr-namespace:TeslaPowerwallLibrary.App.ViewModels"
			 xmlns:views="clr-namespace:TeslaPowerwallLibrary.App.Views"
			 StartupUri="MainWindow.xaml">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="Themes/Theme.xaml" />
			</ResourceDictionary.MergedDictionaries>

			<!-- Converters -->
			<conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
			<conv:InverseBoolConverter x:Key="InverseBool" />
			<conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
			<conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
			<conv:EnumEqualsConverter x:Key="EnumEquals" />

			<!-- View-model to view mappings -->
			<DataTemplate DataType="{x:Type vm:ConnectViewModel}">
				<views:ConnectView />
			</DataTemplate>
			<DataTemplate DataType="{x:Type vm:HomeViewModel}">
				<views:HomeView />
			</DataTemplate>
			<DataTemplate DataType="{x:Type vm:EnergyViewModel}">
				<views:EnergyView />
			</DataTemplate>
			<DataTemplate DataType="{x:Type vm:SettingsViewModel}">
				<views:SettingsView />
			</DataTemplate>
			<DataTemplate DataType="{x:Type vm:SystemViewModel}">
				<views:SystemView />
			</DataTemplate>
		</ResourceDictionary>
	</Application.Resources>
</Application>
