<Window x:Class="TeslaPowerwallLibrary.Setup.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Tesla™ Powerwall™ Setup — Authentication Token"
		Width="560" Height="900"
		WindowStartupLocation="CenterScreen"
		FontFamily="Segoe UI" FontSize="13">
	<Grid Margin="0">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Background="#FF1B1B1B" Padding="16,12">
			<StackPanel>
				<TextBlock Text="⚡ Tesla Authentication — pypowerwall authtoken"
							Foreground="White" FontSize="16" FontWeight="SemiBold" />
				<TextBlock Text="Sign in to generate the tokens needed for Powerwall cloud (Owners API) or FleetAPI mode."
							Foreground="#FFB0B0B0" TextWrapping="Wrap" Margin="0,4,0,0" />
			</StackPanel>
		</Border>

		<TabControl Grid.Row="1" x:Name="ModeTabs">
			<TabItem Header="Cloud (Owners API)">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<!-- Controls -->
					<Border Grid.Row="0" Background="#FFF0F0F0" Padding="16,12">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="Region:" VerticalAlignment="Center" Margin="0,0,8,0" />
							<ComboBox x:Name="RegionSelector" Width="200" SelectedIndex="0" VerticalAlignment="Center">
								<ComboBoxItem Content="United States / International (auth.tesla.com)" Tag="us" />
								<ComboBoxItem Content="China (auth.tesla.cn)" Tag="cn" />
							</ComboBox>
							<Button x:Name="StartButton" Content="Start Login" Width="110" Height="28"
									Margin="12,0,0,0" Click="OnStartLoginClick" />
							<Button x:Name="RestartButton" Content="Restart" Width="80" Height="28"
									Margin="8,0,0,0" Click="OnStartLoginClick" Visibility="Collapsed" />
						</StackPanel>
					</Border>

					<!-- Idle / instructional placeholder -->
					<Border x:Name="PlaceholderPanel" Grid.Row="1" Background="#FFF5F5F5">
						<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
							<TextBlock Text="Select your region and click Start Login."
										FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" />
							<TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="#FF555555" Margin="0,10,0,0"
										Text="A Tesla sign-in window will open. After you authenticate, your Refresh Token (RT) and Access Token (AT) are displayed below. Nothing is saved to disk — copy the tokens into your application configuration." />
						</StackPanel>
					</Border>

					<!-- Token results -->
					<Border x:Name="ResultsPanel" Grid.Row="2" Background="#FFFFFFFF" Padding="16,12"
							BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0" Visibility="Collapsed">
						<StackPanel>
							<TextBlock Text="✅ Authentication successful" Foreground="#FF1B7F32"
										FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />

							<StackPanel x:Name="EmailRow" Orientation="Horizontal" Margin="0,0,0,8">
								<TextBlock Text="Account:" FontWeight="SemiBold" Width="160" VerticalAlignment="Center" />
								<TextBlock x:Name="EmailText" VerticalAlignment="Center" />
							</StackPanel>

							<TextBlock Text="Refresh Token (RT) — valid ~90 days" FontWeight="SemiBold" Margin="0,4,0,2" />
							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>
								<TextBox x:Name="RefreshTokenText" Grid.Column="0" IsReadOnly="True"
										 TextWrapping="Wrap" MaxHeight="90" VerticalScrollBarVisibility="Auto"
										 FontFamily="Consolas" Background="#FFF7F7F7" />
								<Button x:Name="CopyRefreshButton" Grid.Column="1" Content="Copy" Width="70" Height="28"
										Margin="8,0,0,0" VerticalAlignment="Top" Click="OnCopyRefreshClick" />
							</Grid>

							<TextBlock Text="Access Token (AT) — valid ~8 hours" FontWeight="SemiBold" Margin="0,4,0,2" />
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>
								<TextBox x:Name="AccessTokenText" Grid.Column="0" IsReadOnly="True"
										 TextWrapping="Wrap" MaxHeight="90" VerticalScrollBarVisibility="Auto"
										 FontFamily="Consolas" Background="#FFF7F7F7" />
								<Button x:Name="CopyAccessButton" Grid.Column="1" Content="Copy" Width="70" Height="28"
										Margin="8,0,0,0" VerticalAlignment="Top" Click="OnCopyAccessClick" />
							</Grid>

							<TextBlock TextWrapping="Wrap" Foreground="#FF555555" Margin="0,10,0,0"
										Text="The Access Token bootstraps the first connection; afterwards the library auto-refreshes using the Refresh Token. Supply these via PowerwallOptions.AccessToken and PowerwallOptions.RefreshToken (or PW_ACCESS_TOKEN / PW_REFRESH_TOKEN)." />
						</StackPanel>
					</Border>

					<!-- Status bar -->
					<Border Grid.Row="3" Background="#FFEFEFEF" Padding="16,6" BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0">
						<TextBlock x:Name="StatusText" Text="Ready." Foreground="#FF333333" />
					</Border>
				</Grid>
			</TabItem>

			<TabItem Header="FleetAPI">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
						<StackPanel Margin="16,12">
							<TextBlock TextWrapping="Wrap" Foreground="#FF555555" Margin="0,0,0,12"
										Text="Requires a Tesla developer application already registered at developer.tesla.com, with its public PEM key hosted at your domain. Nothing is saved to disk." />

							<TextBlock Text="Client ID" FontWeight="SemiBold" Margin="0,0,0,4" />
							<TextBox x:Name="FleetApiClientIdBox" Margin="0,0,0,10" />

							<TextBlock Text="Client Secret" FontWeight="SemiBold" Margin="0,0,0,4" />
							<PasswordBox x:Name="FleetApiClientSecretBox" Margin="0,0,0,10" />

							<TextBlock Text="Domain (e.g. example.com)" FontWeight="SemiBold" Margin="0,0,0,4" />
							<TextBox x:Name="FleetApiDomainBox" Margin="0,0,0,10" />

							<TextBlock Text="Redirect URI" FontWeight="SemiBold" Margin="0,0,0,4" />
							<TextBox x:Name="FleetApiRedirectUriBox" Margin="0,0,0,10" />

							<TextBlock Text="Region" FontWeight="SemiBold" Margin="0,0,0,4" />
							<ComboBox x:Name="FleetApiRegionSelector" SelectedIndex="0" Margin="0,0,0,12">
								<ComboBoxItem Content="North America / Asia-Pacific" Tag="na" />
								<ComboBoxItem Content="Europe / Middle East / Africa" Tag="eu" />
								<ComboBoxItem Content="China" Tag="cn" />
							</ComboBox>

							<Button x:Name="FleetApiRegisterButton" Content="1. Verify &amp; Register Partner Account"
									Height="30" Click="OnFleetApiRegisterClick" />

							<Border Background="#FFF7F7F7" Padding="10" Margin="0,12,0,0"
									x:Name="FleetApiAuthorizePanel" Visibility="Collapsed">
								<StackPanel>
									<TextBlock Text="2. Visit this URL and authorize access:" FontWeight="SemiBold" Margin="0,0,0,4" />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBox x:Name="FleetApiAuthorizeUrlText" Grid.Column="0" IsReadOnly="True"
												 TextWrapping="Wrap" MaxHeight="90" VerticalScrollBarVisibility="Auto"
												 FontFamily="Consolas" Background="White" />
										<StackPanel Grid.Column="1" Margin="8,0,0,0">
											<Button x:Name="FleetApiOpenBrowserButton" Content="Open" Width="70" Height="28"
													Click="OnFleetApiOpenBrowserClick" Margin="0,0,0,4" />
											<Button x:Name="FleetApiCopyUrlButton" Content="Copy" Width="70" Height="28"
													Click="OnFleetApiCopyUrlClick" />
										</StackPanel>
									</Grid>

									<TextBlock Text="After authorizing, paste the code (or the full redirected URL) here:"
												FontWeight="SemiBold" Margin="0,10,0,4" />
									<TextBox x:Name="FleetApiCodeBox" Margin="0,0,0,10" />

									<Button x:Name="FleetApiExchangeButton" Content="3. Exchange Code for Tokens"
											Height="30" Click="OnFleetApiExchangeClick" />
								</StackPanel>
							</Border>

							<Border x:Name="FleetApiResultsPanel" Background="#FFFFFFFF" Padding="0,12,0,0" Visibility="Collapsed">
								<StackPanel>
									<TextBlock Text="✅ FleetAPI authentication successful" Foreground="#FF1B7F32"
												FontWeight="SemiBold" FontSize="14" Margin="0,4,0,8" />

									<TextBlock Text="Refresh Token — used as PowerwallOptions.FleetApiRefreshToken" FontWeight="SemiBold" Margin="0,4,0,2" />
									<Grid Margin="0,0,0,10">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBox x:Name="FleetApiRefreshTokenText" Grid.Column="0" IsReadOnly="True"
												 TextWrapping="Wrap" MaxHeight="90" VerticalScrollBarVisibility="Auto"
												 FontFamily="Consolas" Background="#FFF7F7F7" />
										<Button Grid.Column="1" Content="Copy" Width="70" Height="28"
												Margin="8,0,0,0" VerticalAlignment="Top" Click="OnFleetApiCopyRefreshClick" />
									</Grid>

									<TextBlock Text="Access Token" FontWeight="SemiBold" Margin="0,4,0,2" />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBox x:Name="FleetApiAccessTokenText" Grid.Column="0" IsReadOnly="True"
												 TextWrapping="Wrap" MaxHeight="90" VerticalScrollBarVisibility="Auto"
												 FontFamily="Consolas" Background="#FFF7F7F7" />
										<Button Grid.Column="1" Content="Copy" Width="70" Height="28"
												Margin="8,0,0,0" VerticalAlignment="Top" Click="OnFleetApiCopyAccessClick" />
									</Grid>
								</StackPanel>
							</Border>
						</StackPanel>
					</ScrollViewer>

					<!-- Status bar -->
					<Border Grid.Row="1" Background="#FFEFEFEF" Padding="16,6" BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0">
						<TextBlock x:Name="FleetApiStatusText" Text="Ready." Foreground="#FF333333" TextWrapping="Wrap" />
					</Border>
				</Grid>
			</TabItem>
		</TabControl>
	</Grid>
</Window>

